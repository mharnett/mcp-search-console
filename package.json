{
  "name": "mcp-google-gsc",
  "mcpName": "io.github.mharnett/google-gsc",
  "version": "1.1.0",
  "description": "MCP server for Google Search Console API with multi-client support, search analytics, and URL inspection.",
  "main": "dist/index.js",
  "bin": {
    "mcp-google-gsc": "dist/index.js",
    "mcp-gsc-auth": "dist/auth-cli.js"
  },
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "config.example.json"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:auth": "tsx src/auth-cli.ts",
    "auth": "node dist/auth-cli.js",
    "test": "vitest run"
  },
  "author": "drak-marketing",
  "license": "MIT",
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "cockatiel": "^3.2.1",
    "env-paths": "^3.0.0",
    "googleapis": "^144.0.0",
    "open": "^10.0.0",
    "pino": "^8.21.0",
    "pino-pretty": "^13.1.3",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/prompts": "^2.4.9",
    "esbuild": "^0.25.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
