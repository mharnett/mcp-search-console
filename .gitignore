node_modules/
dist/
config.json
# Per-client config overrides carry machine-local paths and must never ship or
# be committed. The committed template (config.example.json) is re-included.
config.*.json
!config.example.json
.env
# Per-client launchers carry machine-local paths (/Users/...) and Keychain
# service names. They are never committed and never shipped. The generic
# run-mcp.sh (no absolute paths) IS tracked.
run-forcepoint.sh
run-neon-one.sh
